model Product {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    index Int    @default(1)
    title String
    slug  String @unique

    brand          String
    category       String
    price          Price
    stocks         Int
    description    String
    specifications String?
    images         String[]
    mainImage      String

    likedByUserIds String[] @db.ObjectId

    views Int @default(0)

    isStock   Boolean @default(true)
    isTop     Boolean @default(false)
    isDeleted Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("products")
}

type Price {
    original   Float
    discounted Float
}
