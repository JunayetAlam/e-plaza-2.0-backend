model FilterType {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    name String

    createdAt              DateTime                @default(now())
    updatedAt              DateTime                @updatedAt
    filterTypeFilters      FilterTypeFilter[]
    categoryFilterTypes    CategoryFilterType[]
    subCategoryFilterTypes SubCategoryFilterType[]

    @@map("filter_types")
}

model FilterTypeFilter {
    id       String @id @default(auto()) @map("_id") @db.ObjectId
    filterId String @db.ObjectId
    typeId   String @db.ObjectId

    filter Filter     @relation(fields: [filterId], references: [id])
    type   FilterType @relation(fields: [typeId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("filter_type_filters")
}

model Filter {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    name String

    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    filterProducts    ProductFilter[]
    filterTypeFilters FilterTypeFilter[]

    @@map("filters")
}

model ProductFilter {
    id        String @id @default(auto()) @map("_id") @db.ObjectId
    filterId  String @db.ObjectId
    productId String @db.ObjectId

    filter  Filter  @relation(fields: [filterId], references: [id])
    product Product @relation(fields: [productId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("filter_products")
}

model CategoryFilterType {
    id         String @id @default(auto()) @map("_id") @db.ObjectId
    typeId     String @db.ObjectId
    categoryId String @db.ObjectId

    type     FilterType @relation(fields: [typeId], references: [id])
    category Category   @relation(fields: [categoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("category_filter_types")
}

model SubCategoryFilterType {
    id            String @id @default(auto()) @map("_id") @db.ObjectId
    typeId        String @db.ObjectId
    subCategoryId String @db.ObjectId

    type        FilterType  @relation(fields: [typeId], references: [id])
    subCategory SubCategory @relation(fields: [subCategoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("sub_category_filter_types")
}
